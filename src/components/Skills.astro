---
import '../styles/Skills.css'
---

<section id="skills">
  <p class="skills-label reveal">// MY TOOLKIT</p>
  <h2 class="skills-title reveal">Skills & Tools</h2>
  <div class="skills-grid">
    <div class="skill-cat reveal">
      <div class="skill-cat-title">Languages</div>
      <div class="skill-row"><i class="devicon-java-plain"></i> Java</div>
      <div class="skill-row"><i class="devicon-html5-plain"></i> HTML5</div>
      <div class="skill-row"><i class="devicon-css3-plain"></i> CSS3</div>
      <div class="skill-row"><i class="devicon-javascript-plain"></i> JavaScript</div>
    </div>
    <div class="skill-cat reveal">
      <div class="skill-cat-title">Minecraft Dev</div>
      <div class="skill-row"><i class="devicon-java-plain"></i> Fabric API</div>
      <div class="skill-row"><i class="devicon-java-plain"></i> Mixins</div>
      <div class="skill-row"><i class="devicon-java-plain"></i> Datapacks</div>
      <div class="skill-row"><i class="devicon-java-plain"></i> Fabric Loom</div>
    </div>
    <div class="skill-cat reveal">
      <div class="skill-cat-title">Tools</div>
      <div class="skill-row"><i class="devicon-git-plain"></i> Git & GitHub</div>
      <div class="skill-row"><i class="devicon-github-original"></i> GitHub Pages</div>
      <div class="skill-row"><i class="devicon-intellij-plain"></i> IntelliJ IDEA</div>
      <div class="skill-row"><i class="devicon-vscode-plain"></i> VS Code</div>
    </div>
    <div class="skill-cat reveal">
      <div class="skill-cat-title">Currently Learning</div>
      <div class="skill-row"><i class="devicon-astro-plain"></i> Astro</div>
      <div class="skill-row"><i class="devicon-tailwindcss-plain"></i> Tailwind CSS</div>
      <div class="skill-row"><i class="devicon-c-plain"></i> C</div>
    </div>
  </div>
</section>