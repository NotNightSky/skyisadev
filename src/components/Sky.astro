---
import '../styles/Sky.css'
---

<section id="home">
  <div class="sky-text">
    <div class="sky-badge">16 y/o Mod Developer</div>
    <h1 class="sky-name">
      Hi, I'm<br><span class="hl">Sky</span><span class="cursor"></span>
    </h1>
    <p class="sky-tagline">
      I craft <strong>Minecraft mods</strong> in Java and... well, sometimes build <strong>websites</strong> and
      turning my imagination into real, playable & usable stuff.
    </p>
    <div class="sky-stack">
      <span class="tag java">Java</span>
      <span class="tag mc">Minecraft Modding</span>
      <span class="tag web">HTML / CSS / JS</span>
      <span class="tag">Fabric</span>
      <span class="tag web">GitHub Pages</span>
    </div>
    <div class="sky-cta">
      <a class="btn btn-primary" href="#projects">View Projects</a>
      <a class="btn btn-ghost" href="https://github.com/notnightsky" target="_blank">GitHub ↗</a>
    </div>
  </div>
</section>